# Food Delivery App - Environment Variables Template
# Copy this to backend/.env and frontend/.env after updating values

# ==========================================
# BACKEND ENVIRONMENT (.env in backend/)
# ==========================================

# Server Configuration
PORT=5000
NODE_ENV=development

# Database (Supabase)
# Get from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...your_anon_key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...your_service_role_key

# Authentication
JWT_SECRET=your-secret-key-change-in-production-123456
JWT_EXPIRY=7d

# Payment Gateway (Razorpay)
# Get from your Razorpay account
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxx

# Email Configuration (Optional - Mailtrap)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=465
SMTP_USER=your_mailtrap_username
SMTP_PASS=your_mailtrap_password

# Application URLs
APP_URL=http://localhost:3000
API_URL=http://localhost:5000

# ==========================================
# FRONTEND ENVIRONMENT (.env in frontend/)
# ==========================================

VITE_API_URL=http://localhost:5000/api
VITE_APP_NAME=Food Delivery

# ==========================================
# SETUP INSTRUCTIONS
# ==========================================

# 1. Backend Setup:
#    - Create backend/.env file
#    - Copy backend config from above
#    - Get Supabase credentials from https://supabase.com
#    - Get Razorpay keys from https://razorpay.com

# 2. Frontend Setup:
#    - Create frontend/.env file
#    - Copy frontend config from above
#    - Update VITE_API_URL if backend is on different host

# 3. Supabase Setup:
#    Step 1: Create project at supabase.com
#    Step 2: In SQL Editor, run database/schema.sql
#    Step 3: Then run database/seed-data.sql
#    Step 4: Copy credentials to backend/.env

# 4. Razorpay Setup:
#    Step 1: Create account at razorpay.com
#    Step 2: Go to Settings > API Keys
#    Step 3: Copy Key ID and Secret
#    Step 4: Use sandbox keys for testing

# 5. Start the application:
#    Terminal 1: cd backend && npm run dev
#    Terminal 2: cd frontend && npm run dev
#    Then visit: http://localhost:3000

# ==========================================
# HELPFUL NOTES
# ==========================================

# Testing Payment:
# Use test card: 4111 1111 1111 1111
# Expiry: Any future date (e.g., 12/25)
# CVV: Any 3 digits (e.g., 123)

# Demo Credentials:
# Customer: customer1@example.com / admin123
# Admin: admin@fooddelivery.com / admin123
# Agent: agent1@fooddelivery.com / admin123

# Security:
# - Never commit .env files
# - Change JWT_SECRET for production
# - Use strong passwords
# - Keep API keys private
